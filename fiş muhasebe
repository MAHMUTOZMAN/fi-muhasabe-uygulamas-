class Database:
    def __init__(self, path=DB_FILE):
        self.path = Path(path)
        self.conn = sqlite3.connect(str(self.path))
        self.ensure_tables()

    def ensure_tables(self):
        cur = self.conn.cursor()
        cur.executescript(CREATE_TABLES_SQL)
        self.conn.commit()

    # Fiş ile ilgili metotlar (değişiklik yok)
    def insert_receipt(self, name, phone, address, tc):
        cur = self.conn.cursor()
        now = datetime.now().isoformat(sep=" ", timespec="seconds")
        cur.execute(
            "INSERT INTO receipts (name, phone, address, tc, created_at, is_deleted) VALUES (?, ?, ?, ?, ?, 0)",
            (name, phone, address, tc, now)
        )
        self.conn.commit()
        return cur.lastrowid

    def insert_receipt_item(self, receipt_id, product_code, quantity, price):
        cur = self.conn.cursor()
        cur.execute("UPDATE products SET stock_quantity = stock_quantity - ? WHERE code = ?",
                    (quantity, product_code))
        cur.execute(
            "INSERT INTO receipt_items (receipt_id, product_code, quantity, price) VALUES (?, ?, ?, ?)",
            (receipt_id, product_code, quantity, price)
        )
        self.conn.commit()

    def update_receipt(self, rec_id, name, phone, address, tc, old_items):
        cur = self.conn.cursor()
        for item in old_items:
            product_code = item[4]
            quantity = item[2]
            cur.execute("UPDATE products SET stock_quantity = stock_quantity + ? WHERE code = ?",
                        (quantity, product_code))

        cur.execute(
            "UPDATE receipts SET name=?, phone=?, address=?, tc=? WHERE id=?",
            (name, phone, address, tc, rec_id)
        )
        self.conn.commit()
        cur.execute("DELETE FROM receipt_items WHERE receipt_id=?", (rec_id,))
        self.conn.commit()

    def fetch_receipt_items(self, receipt_id):
        cur = self.conn.cursor()
        cur.execute(
            "SELECT ri.id, p.name, ri.quantity, ri.price, p.code FROM receipt_items ri INNER JOIN products p ON ri.product_code = p.code WHERE ri.receipt_id = ?",
            (receipt_id,)
        )
        return cur.fetchall()

    def remove_receipt_item(self, item_id):
        cur = self.conn.cursor()
        cur.execute("SELECT product_code, quantity FROM receipt_items WHERE id = ?", (item_id,))
        product_code, quantity = cur.fetchone()
        cur.execute("UPDATE products SET stock_quantity = stock_quantity + ? WHERE code = ?",
                    (quantity, product_code))
        cur.execute("DELETE FROM receipt_items WHERE id=?", (item_id,))
        self.conn.commit()

    def soft_delete_receipt(self, rec_id):
        cur = self.conn.cursor()
        cur.execute("SELECT product_code, quantity FROM receipt_items WHERE receipt_id = ?", (rec_id,))
        items = cur.fetchall()
        for product_code, quantity in items:
            cur.execute("UPDATE products SET stock_quantity = stock_quantity + ? WHERE code = ?",
                        (quantity, product_code))
        cur.execute("UPDATE receipts SET is_deleted=1 WHERE id=?", (rec_id,))
        self.conn.commit()

    def restore_receipt(self, rec_id):
        cur = self.conn.cursor()
        cur.execute("SELECT product_code, quantity FROM receipt_items WHERE receipt_id = ?", (rec_id,))
        items = cur.fetchall()
        for product_code, quantity in items:
            cur.execute("UPDATE products SET stock_quantity = stock_quantity - ? WHERE code = ?",
                        (quantity, product_code))
        cur.execute("UPDATE receipts SET is_deleted=0 WHERE id=?", (rec_id,))
        self.conn.commit()

    def hard_delete_receipt(self, rec_id):
        cur = self.conn.cursor()
        cur.execute("SELECT product_code, quantity FROM receipt_items WHERE receipt_id = ?", (rec_id,))
        items = cur.fetchall()
        if items:
            for product_code, quantity in items:
                cur.execute("UPDATE products SET stock_quantity = stock_quantity + ? WHERE code = ?",
                            (quantity, product_code))
        cur.execute("DELETE FROM receipt_items WHERE receipt_id=?", (rec_id,))
        cur.execute("DELETE FROM receipts WHERE id=?", (rec_id,))
        self.conn.commit()

    def fetch_all_receipts(self, only_deleted=False, search_term="", start_date=None, end_date=None):
        cur = self.conn.cursor()
        sql_query = "SELECT id, name, phone, address, tc, created_at, is_deleted FROM receipts "
        params = []
        where_clauses = []

        if only_deleted:
            where_clauses.append("is_deleted = 1")
        else:
            where_clauses.append("is_deleted = 0")

        if search_term.strip():
            search_term_like = f"%{search_term.strip().lower()}%"
            where_clauses.append(
                "(LOWER(name) LIKE ? OR LOWER(phone) LIKE ? OR LOWER(tc) LIKE ?)")
            params.extend([search_term_like, search_term_like, search_term_like])

        if start_date and end_date:
            start_date_str = start_date.toString("yyyy-MM-dd 00:00:00")
            end_date_str = end_date.toString("yyyy-MM-dd 23:59:59")
            where_clauses.append("created_at BETWEEN ? AND ?")
            params.extend([start_date_str, end_date_str])

        if where_clauses:
            sql_query += " WHERE " + " AND ".join(where_clauses)

        sql_query += " ORDER BY id DESC"
        cur.execute(sql_query, tuple(params))
        return cur.fetchall()

    def fetch_receipt_by_id(self, rec_id):
        cur = self.conn.cursor()
        cur.execute(
            "SELECT id, name, phone, address, tc, created_at, is_deleted FROM receipts WHERE id=?",
            (rec_id,)
        )
        return cur.fetchone()

    # Ürün yönetimi metotları (değişiklik yok)
    def insert_product(self, code, name, price, stock, min_stock, description):
        cur = self.conn.cursor()
        cur.execute(
            "INSERT INTO products (code, name, price, stock_quantity, min_stock, description) VALUES (?, ?, ?, ?, ?, ?)",
            (code, name, price, stock, min_stock, description))
        self.conn.commit()

    def update_product(self, prod_id, code, name, price, stock, min_stock, description):
        cur = self.conn.cursor()
        cur.execute(
            "UPDATE products SET code=?, name=?, price=?, stock_quantity=?, min_stock=?, description=? WHERE id=?",
            (code, name, price, stock, min_stock, description, prod_id))
        self.conn.commit()

    def delete_product(self, prod_id):
        cur = self.conn.cursor()
        cur.execute("DELETE FROM products WHERE id=?", (prod_id,))
        self.conn.commit()

    def fetch_all_products(self):
        cur = self.conn.cursor()
        cur.execute(
            "SELECT id, code, name, price, stock_quantity, min_stock, description FROM products ORDER BY id DESC")
        return cur.fetchall()

    def fetch_low_stock_products(self):
        cur = self.conn.cursor()
        cur.execute(
            "SELECT name, stock_quantity, min_stock FROM products WHERE stock_quantity <= min_stock ORDER BY stock_quantity ASC")
        return cur.fetchall()

    def fetch_product_by_code(self, code):
        cur = self.conn.cursor()
        cur.execute("SELECT id, code, name, price, stock_quantity, min_stock, description FROM products WHERE code=?",
                    (code,))
        return cur.fetchone()

    def fetch_product_by_id(self, prod_id):
        cur = self.conn.cursor()
        cur.execute("SELECT id, code, name, price, stock_quantity, min_stock, description FROM products WHERE id=?",
                    (prod_id,))
        return cur.fetchone()

    def fetch_report_data(self, start_date, end_date):
        cur = self.conn.cursor()
        start_date_str = start_date.toString("yyyy-MM-dd 00:00:00")
        end_date_str = end_date.toString("yyyy-MM-dd 23:59:59")

        # Fiş (Satış) Gelirleri
        cur.execute("""
            SELECT
                SUM(ri.quantity * ri.price) AS total_revenue
            FROM receipt_items ri
            INNER JOIN receipts r ON ri.receipt_id = r.id
            WHERE r.is_deleted = 0 AND r.created_at BETWEEN ? AND ?
        """, (start_date_str, end_date_str))
        total_receipt_revenue = cur.fetchone()[0] or 0.0

        # Ek Gelirler
        cur.execute("""
            SELECT
                SUM(amount)
            FROM income_expenses
            WHERE type='income' AND created_at BETWEEN ? AND ?
        """, (start_date_str, end_date_str))
        total_other_income = cur.fetchone()[0] or 0.0

        # Giderler
        cur.execute("""
            SELECT
                SUM(amount)
            FROM income_expenses
            WHERE type='expense' AND created_at BETWEEN ? AND ?
        """, (start_date_str, end_date_str))
        total_expenses = cur.fetchone()[0] or 0.0

        # Fiş ve Adet Sayıları
        cur.execute("""
            SELECT
                SUM(ri.quantity) AS total_quantity,
                COUNT(DISTINCT r.id) AS total_receipts
            FROM receipt_items ri
            INNER JOIN receipts r ON ri.receipt_id = r.id
            WHERE r.is_deleted = 0 AND r.created_at BETWEEN ? AND ?
        """, (start_date_str, end_date_str))
        receipt_summary = cur.fetchone()

        total_quantity = receipt_summary[0] or 0
        total_receipts = receipt_summary[1] or 0

        # Ürün Kırılımı
        cur.execute("""
            SELECT
                p.name,
                p.code,
                SUM(ri.quantity) AS total_sold_quantity,
                SUM(ri.quantity * ri.price) AS total_revenue
            FROM receipt_items ri
            INNER JOIN receipts r ON ri.receipt_id = r.id
            INNER JOIN products p ON ri.product_code = p.code
            WHERE r.is_deleted = 0 AND r.created_at BETWEEN ? AND ?
            GROUP BY p.code
            ORDER BY total_revenue DESC
        """, (start_date_str, end_date_str))
        product_breakdown = cur.fetchall()

        return {
            'total_revenue': total_receipt_revenue,
            'total_other_income': total_other_income,
            'total_expenses': total_expenses,
            'total_quantity': total_quantity,
            'total_receipts': total_receipts,
            'product_breakdown': product_breakdown
        }

    def fetch_dashboard_data(self):
        now = datetime.now()
        start_of_day = now.replace(hour=0, minute=0, second=0, microsecond=0)
        end_of_day = now.replace(hour=23, minute=59, second=59, microsecond=999999)
        start_of_month = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)

        cur = self.conn.cursor()

        # Günlük ve aylık fiş gelirleri
        cur.execute("""
            SELECT SUM(ri.quantity * ri.price), COUNT(DISTINCT r.id)
            FROM receipt_items ri
            JOIN receipts r ON ri.receipt_id = r.id
            WHERE r.created_at BETWEEN ? AND ? AND r.is_deleted = 0
        """, (start_of_day.isoformat(), end_of_day.isoformat()))
        daily_summary = cur.fetchone()

        cur.execute("""
            SELECT SUM(ri.quantity * ri.price), COUNT(DISTINCT r.id)
            FROM receipt_items ri
            JOIN receipts r ON ri.receipt_id = r.id
            WHERE r.created_at BETWEEN ? AND ? AND r.is_deleted = 0
        """, (start_of_month.isoformat(), end_of_day.isoformat()))
        monthly_summary = cur.fetchone()

        # YENİ ÖZELLİK: Günlük ve aylık ek gelir ve giderler
        cur.execute("""
            SELECT SUM(CASE WHEN type = 'income' THEN amount ELSE 0 END),
                   SUM(CASE WHEN type = 'expense' THEN amount ELSE 0 END)
            FROM income_expenses
            WHERE created_at BETWEEN ? AND ?
        """, (start_of_day.isoformat(), end_of_day.isoformat()))
        daily_income_expense = cur.fetchone()

        cur.execute("""
            SELECT SUM(CASE WHEN type = 'income' THEN amount ELSE 0 END),
                   SUM(CASE WHEN type = 'expense' THEN amount ELSE 0 END)
            FROM income_expenses
            WHERE created_at BETWEEN ? AND ?
        """, (start_of_month.isoformat(), end_of_day.isoformat()))
        monthly_income_expense = cur.fetchone()

        low_stock_products = self.fetch_low_stock_products()

        cur.execute("SELECT COUNT(id) FROM products")
        total_products = cur.fetchone()[0]

        cur.execute("SELECT COUNT(DISTINCT name) FROM receipts WHERE is_deleted=0 AND name !=''")
        total_customers = cur.fetchone()[0]

        return {
            'daily_receipt_revenue': daily_summary[0] if daily_summary and daily_summary[0] else 0.0,
            'daily_receipts': daily_summary[1] if daily_summary and daily_summary[1] else 0,
            'monthly_receipt_revenue': monthly_summary[0] if monthly_summary and monthly_summary[0] else 0.0,
            'monthly_receipts': monthly_summary[1] if monthly_summary and monthly_summary[1] else 0,

            # YENİ ÖZELLİK: Günlük ve aylık muhasebe verileri
            'daily_other_income': daily_income_expense[0] if daily_income_expense and daily_income_expense[0] else 0.0,
            'daily_expenses': daily_income_expense[1] if daily_income_expense and daily_income_expense[1] else 0.0,
            'monthly_other_income': monthly_income_expense[0] if monthly_income_expense and monthly_income_expense[
                0] else 0.0,
            'monthly_expenses': monthly_income_expense[1] if monthly_income_expense and monthly_income_expense[
                1] else 0.0,

            'low_stock_products': low_stock_products,
            'total_products': total_products,
            'total_customers': total_customers,
        }

    def fetch_recent_activity(self, limit=5):
        cur = self.conn.cursor()
        cur.execute("""
            SELECT r.id, r.name, r.created_at, SUM(ri.quantity * ri.price)
            FROM receipts r
            LEFT JOIN receipt_items ri ON r.id = ri.receipt_id
            WHERE r.is_deleted = 0
            GROUP BY r.id
            ORDER BY r.created_at DESC
            LIMIT ?
        """, (limit,))
        return cur.fetchall()

    # YENİ ÖZELLİK: Gelir/gider yönetimi metotları
    def insert_income_expense(self, type, description, amount):
        cur = self.conn.cursor()
        now = datetime.now().isoformat(sep=" ", timespec="seconds")
        cur.execute(
            "INSERT INTO income_expenses (type, description, amount, created_at) VALUES (?, ?, ?, ?)",
            (type, description, amount, now)
        )
        self.conn.commit()

    def fetch_all_income_expenses(self, start_date=None, end_date=None):
        cur = self.conn.cursor()
        sql_query = "SELECT id, type, description, amount, created_at FROM income_expenses "
        params = []
        where_clauses = []

        if start_date and end_date:
            start_date_str = start_date.toString("yyyy-MM-dd 00:00:00")
            end_date_str = end_date.toString("yyyy-MM-dd 23:59:59")
            where_clauses.append("created_at BETWEEN ? AND ?")
            params.extend([start_date_str, end_date_str])

        if where_clauses:
            sql_query += " WHERE " + " AND ".join(where_clauses)

        sql_query += " ORDER BY created_at DESC"
        cur.execute(sql_query, tuple(params))
        return cur.fetchall()

    def delete_income_expense(self, record_id):
        cur = self.conn.cursor()
        cur.execute("DELETE FROM income_expenses WHERE id=?", (record_id,))
        self.conn.commit()


