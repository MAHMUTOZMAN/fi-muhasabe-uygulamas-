    def load_all_product_data(self):
        self.product_list = self.db.fetch_all_products()
        product_names = [p[2] for p in self.product_list]
        self.product_name_completer.setModel(QStringListModel(product_names))

    def fill_product_details(self, text):
        for product in self.product_list:
            if product[2] == text:
                self.product_code_input.setText(product[1])
                self.product_price_input.setText(str(product[3]))
                self.product_quantity_input.setFocus()
                return

    def add_product_to_receipt(self):
        product_code = self.product_code_input.text().strip()
        product_name = self.product_name_input.text().strip()
        quantity = self.product_quantity_input.value()
        price = self.product_price_input.text().strip()

        if not product_code or not product_name or not price:
            QMessageBox.warning(self, "Hata", "Ürün kodu, adı ve fiyatı boş bırakılamaz.")
            return

        try:
            price = Decimal(price.replace(',', '.')).quantize(Decimal('0.01'), rounding=ROUND_HALF_UP)

            # Ürün kodu zaten tabloda varsa uyarı ver
            for row in range(self.receipt_items_table.rowCount()):
                if self.receipt_items_table.item(row, 0).text() == product_code:
                    QMessageBox.warning(self, "Hata", "Bu ürün zaten fiş listesinde.")
                    return

            # Stok kontrolü
            product_data = self.db.fetch_product_by_code(product_code)
            if product_data:
                available_stock = product_data[4]
                if quantity > available_stock:
                    QMessageBox.warning(self, "Hata", f"Yeterli stok yok. Mevcut stok: {available_stock}")
                    return

            # Tabloya ekle
            row_count = self.receipt_items_table.rowCount()
            self.receipt_items_table.setRowCount(row_count + 1)

            item_id = ""  # Yeni kayıt olduğu için ID boş
            self.receipt_items_table.setItem(row_count, 0, QTableWidgetItem(str(item_id)))
            self.receipt_items_table.setItem(row_count, 1, QTableWidgetItem(product_name))
            self.receipt_items_table.setItem(row_count, 2, QTableWidgetItem(str(quantity)))
            self.receipt_items_table.setItem(row_count, 3, QTableWidgetItem(f"{price:.2f} ₺"))

            # Clear inputs
            self.product_code_input.clear()
            self.product_name_input.clear()
            self.product_quantity_input.setValue(1)
            self.product_price_input.clear()

            self.update_total_price()

        except ValueError:
            QMessageBox.warning(self, "Hata", "Lütfen geçerli bir fiyat girin.")

    def remove_product_from_receipt(self):
        selected_rows = self.receipt_items_table.selectionModel().selectedRows()
        if not selected_rows:
            QMessageBox.warning(self, "Hata", "Lütfen silinecek bir ürün seçin.")
            return

        row_index = selected_rows[0].row()
        item_id = self.receipt_items_table.item(row_index, 0).text()

        if item_id:  # Kayıtlı bir fişten ürün siliniyor
            reply = QMessageBox.question(self, "Onay",
                                         "Bu ürünü fişten kaldırmak istediğinizden emin misiniz? Stok miktarı güncellenecektir.",
                                         QMessageBox.Yes | QMessageBox.No)
            if reply == QMessageBox.Yes:
                self.db.remove_receipt_item(int(item_id))
                self.receipt_items_table.removeRow(row_index)
                self.update_total_price()
        else:  # Yeni bir fişteki ürünü silme
            self.receipt_items_table.removeRow(row_index)
            self.update_total_price()

    def update_total_price(self):
        total = Decimal('0.00')
        for row in range(self.receipt_items_table.rowCount()):
            quantity = self.receipt_items_table.item(row, 2).text()
            price = self.receipt_items_table.item(row, 3).text().replace(' ₺', '').replace(',', '.')
            if quantity and price:
                total += Decimal(quantity) * Decimal(price)
        self.total_price_label.setText(f"Toplam Fiyat: <b>{total:,.2f} ₺</b>")

    def save_receipt(self):
        customer_name = self.customer_name_input.text().strip()
        customer_phone = self.customer_phone_input.text().strip()
        customer_address = self.customer_address_input.toPlainText().strip()
        customer_tc = self.customer_tc_input.text().strip()

        if not customer_name:
            QMessageBox.warning(self, "Hata", "Müşteri adı boş bırakılamaz.")
            return

        if self.receipt_items_table.rowCount() == 0:
            QMessageBox.warning(self, "Hata", "Fişe en az bir ürün eklemelisiniz.")
            return

        if self.is_edit_mode:
            # Önce eski fiş kalemlerini stoklara geri ekle
            old_items = self.db.fetch_receipt_items(self.editing_record_id)
            self.db.update_receipt(self.editing_record_id, customer_name, customer_phone, customer_address, customer_tc,
                                   old_items)

            # Sonra yeni fiş kalemlerini ekle
            for row in range(self.receipt_items_table.rowCount()):
                product_code = self.receipt_items_table.item(row,
                                                             0).text()  # Normalde bu tablo item'de product code yok, sadece isim var.
                # Bu kısım hatalı çalışır, ancak ürün listesi ve fiş listesi doğru şekilde
                # eşleştirilebilirse düzeltilebilir. Burayı şimdilik ürün ismini kullanarak
                # kodunu bulacak şekilde ayarlayacağım.
                product_name = self.receipt_items_table.item(row, 1).text()
                quantity = int(self.receipt_items_table.item(row, 2).text())
                price = Decimal(self.receipt_items_table.item(row, 3).text().replace(' ₺', '').replace(',', '.'))

                # Product Code'u bul
                prod_code_from_name = next((p[1] for p in self.product_list if p[2] == product_name), None)

                if prod_code_from_name:
                    self.db.insert_receipt_item(self.editing_record_id, prod_code_from_name, quantity, float(price))
                else:
                    QMessageBox.warning(self, "Hata", f"'{product_name}' isimli ürün bulunamadı. Fiş güncellenemedi.")
                    return

            QMessageBox.information(self, "Başarılı", "Fiş başarıyla güncellendi.")
            self.is_edit_mode = False
            self.editing_record_id = None
        else:
            receipt_id = self.db.insert_receipt(customer_name, customer_phone, customer_address, customer_tc)

            for row in range(self.receipt_items_table.rowCount()):
                product_name = self.receipt_items_table.item(row, 1).text()
                quantity = int(self.receipt_items_table.item(row, 2).text())
                price = Decimal(self.receipt_items_table.item(row, 3).text().replace(' ₺', '').replace(',', '.'))

                prod_code_from_name = next((p[1] for p in self.product_list if p[2] == product_name), None)

                if prod_code_from_name:
                    self.db.insert_receipt_item(receipt_id, prod_code_from_name, quantity, float(price))
                else:
                    QMessageBox.warning(self, "Hata", f"'{product_name}' isimli ürün bulunamadı. Fiş kaydedilemedi.")
                    return

            QMessageBox.information(self, "Başarılı", "Yeni fiş başarıyla kaydedildi.")

        self.clear_receipt_form()
        self.load_receipts_table()
        self.update_dashboard_data()

    def clear_receipt_form(self):
        self.customer_name_input.clear()
        self.customer_phone_input.clear()
        self.customer_address_input.clear()
        self.customer_tc_input.clear()
        self.receipt_items_table.setRowCount(0)
        self.total_price_label.setText("Toplam Fiyat: <b>0.00 ₺</b>")
        self.is_edit_mode = False
        self.editing_record_id = None
        self.save_receipt_button.setText("Fişi Kaydet")

    def load_receipts_table(self, only_deleted=False):
        self.receipts_table.setRowCount(0)
        search_term = self.receipt_search_input.text() if hasattr(self, 'receipt_search_input') else ""
        start_date = self.receipt_start_date.date() if hasattr(self, 'receipt_start_date') else None
        end_date = self.receipt_end_date.date() if hasattr(self, 'receipt_end_date') else None

        self.receipts_table_data = self.db.fetch_all_receipts(only_deleted, search_term, start_date, end_date)
        self.receipts_table.setRowCount(len(self.receipts_table_data))

        for row_num, row_data in enumerate(self.receipts_table_data):
            rec_id, name, phone, address, tc, created_at, is_deleted = row_data

            # Toplam tutarı hesapla
            items = self.db.fetch_receipt_items(rec_id)
            total_amount = sum(item[2] * item[3] for item in items)

            self.receipts_table.setItem(row_num, 0, QTableWidgetItem(str(rec_id)))
            self.receipts_table.setItem(row_num, 1, QTableWidgetItem(name))
            self.receipts_table.setItem(row_num, 2, QTableWidgetItem(phone))
            self.receipts_table.setItem(row_num, 3, QTableWidgetItem(created_at.split(' ')[0]))
            self.receipts_table.setItem(row_num, 4, QTableWidgetItem(f"{total_amount:,.2f} ₺"))

            # İşlem butonları
            actions_widget = QWidget()
            actions_layout = QHBoxLayout(actions_widget)
            actions_layout.setContentsMargins(0, 0, 0, 0)
            actions_layout.setAlignment(Qt.AlignCenter)

            if only_deleted:
                restore_button = QPushButton("Geri Al")
                restore_button.clicked.connect(lambda _, r=rec_id: self.restore_receipt_record(r))
                delete_button = QPushButton("Kalıcı Sil")
                delete_button.clicked.connect(lambda _, r=rec_id: self.hard_delete_receipt_record(r))
                delete_button.setProperty("danger", True)
                actions_layout.addWidget(restore_button)
                actions_layout.addWidget(delete_button)
            else:
                edit_button = QPushButton("Düzenle")
                edit_button.clicked.connect(lambda _, r=rec_id: self.edit_receipt_record(r))
                delete_button = QPushButton("Sil")
                delete_button.clicked.connect(lambda _, r=rec_id: self.soft_delete_receipt_record(r))
                delete_button.setProperty("danger", True)

                print_button = QPushButton("Yazdır")
                print_button.clicked.connect(lambda _, r=rec_id: self.print_receipt(r))

                actions_layout.addWidget(edit_button)
                actions_layout.addWidget(delete_button)
                actions_layout.addWidget(print_button)

            self.receipts_table.setCellWidget(row_num, 5, actions_widget)

        self.receipts_table.resizeColumnsToContents()
        self.receipts_table.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)

    def reset_receipt_filters(self):
        self.receipt_search_input.clear()
        self.receipt_start_date.setDate(QDate.currentDate().addDays(-30))
        self.receipt_end_date.setDate(QDate.currentDate())
        self.load_receipts_table()

    def handle_receipts_table_click(self, row, column):
        if column == 5:  # "İşlemler" sütunu
            return  # Butonun kendi sinyali var, burada bir şey yapmaya gerek yok
        rec_id = int(self.receipts_table.item(row, 0).text())
        self.edit_receipt_record(rec_id)

    def edit_receipt_record(self, rec_id):
        self.is_edit_mode = True
        self.editing_record_id = rec_id
        self.save_receipt_button.setText("Fişi Güncelle")

        # Fiş bilgilerini yükle
        receipt = self.db.fetch_receipt_by_id(rec_id)
        if receipt:
            self.customer_name_input.setText(receipt[1])
            self.customer_phone_input.setText(receipt[2])
            self.customer_address_input.setText(receipt[3])
            self.customer_tc_input.setText(receipt[4])

        # Fiş kalemlerini yükle
        self.receipt_items_table.setRowCount(0)
        items = self.db.fetch_receipt_items(rec_id)
        self.receipt_items_table.setRowCount(len(items))
        for row_num, item in enumerate(items):
            item_id, product_name, quantity, price, product_code = item
            self.receipt_items_table.setItem(row_num, 0, QTableWidgetItem(str(item_id)))
            self.receipt_items_table.setItem(row_num, 1, QTableWidgetItem(product_name))
            self.receipt_items_table.setItem(row_num, 2, QTableWidgetItem(str(quantity)))
            self.receipt_items_table.setItem(row_num, 3, QTableWidgetItem(f"{price:.2f} ₺"))

        self.update_total_price()
        self.tab_widget.setCurrentIndex(1)

    def soft_delete_receipt_record(self, rec_id):
        reply = QMessageBox.question(self, "Onay",
                                     "Bu fişi silmek istediğinizden emin misiniz? Fiş arşive taşınacaktır.",
                                     QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.db.soft_delete_receipt(rec_id)
            self.load_receipts_table()
            self.update_dashboard_data()
            self.load_archive_table()
            QMessageBox.information(self, "Başarılı", "Fiş başarıyla arşive taşındı.")

    def restore_receipt_record(self, rec_id):
        reply = QMessageBox.question(self, "Onay",
                                     "Bu fişi geri almak istediğinizden emin misiniz? Ürün stokları güncellenecektir.",
                                     QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.db.restore_receipt(rec_id)
            self.load_archive_table()
            self.update_dashboard_data()
            self.load_receipts_table()
            QMessageBox.information(self, "Başarılı", "Fiş başarıyla geri alındı.")

    def hard_delete_receipt_record(self, rec_id):
        reply = QMessageBox.question(self, "Uyarı",
                                     "Bu fişi kalıcı olarak silmek istediğinizden emin misiniz? Bu işlem geri alınamaz!",
                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.db.hard_delete_receipt(rec_id)
            self.load_archive_table()
            self.update_dashboard_data()
            QMessageBox.information(self, "Başarılı", "Fiş kalıcı olarak silindi.")

    def print_receipt(self, rec_id=None):
        if not rec_id:
            if self.is_edit_mode:
                rec_id = self.editing_record_id
            else:
                QMessageBox.warning(self, "Hata", "Lütfen yazdırmak için bir fiş seçin veya düzenleme modunda olun.")
                return

        receipt_data = self.db.fetch_receipt_by_id(rec_id)
        if not receipt_data:
            QMessageBox.warning(self, "Hata", "Fiş bilgisi bulunamadı.")
            return

        receipt_items = self.db.fetch_receipt_items(rec_id)

        # HTML İçeriği oluşturma
        html_content = self.generate_receipt_html(receipt_data, receipt_items)

        document = QTextDocument()
        document.setHtml(html_content)

        printer = QPrinter(QPrinter.HighResolution)
        print_dialog = QPrintDialog(printer, self)

        if print_dialog.exec() == QDialog.Accepted:
            document.print(printer)

    def generate_receipt_html(self, receipt_data, receipt_items):
        receipt_id, name, phone, address, tc, created_at, _ = receipt_data

        items_html = ""
        total_price = Decimal('0.00')
        for _, item_name, quantity, price, _ in receipt_items:
            subtotal = Decimal(quantity) * Decimal(price)
            total_price += subtotal
            items_html += f"""
                <tr>
                    <td>{item_name}</td>
                    <td style="text-align: right;">{quantity}</td>
                    <td style="text-align: right;">{price:.2f} ₺</td>
                    <td style="text-align: right;">{subtotal:.2f} ₺</td>
                </tr>
            """

        html = f"""
        <html>
        <head>
        <style>
            body {{ font-family: 'Segoe UI', Arial, sans-serif; font-size: 10pt; line-height: 1.6; margin: 20px; }}
            .receipt-container {{ width: 280px; margin: auto; border: 1px dashed #000; padding: 10px; }}
            .header, .footer {{ text-align: center; }}
            .details {{ margin-top: 10px; }}
            .items-table {{ width: 100%; border-collapse: collapse; margin-top: 10px; }}
            .items-table th, .items-table td {{ padding: 5px; border-bottom: 1px dashed #ccc; }}
            .total {{ text-align: right; margin-top: 10px; font-size: 12pt; font-weight: bold; }}
            hr {{ border: none; border-top: 1px dashed #ccc; }}
        </style>
        </head>
        <body>
            <div class="receipt-container">
                <div class="header">
                    <h2>Özman Dayanıklı Tüketim</h2>
                    <p>Adres: Cumhuriyet Caddesi No:1, Merkez<br/>Telefon: 05xx xxx xx xx</p>
                    <p><strong>Fiş No: {receipt_id}</strong><br/>Tarih: {created_at.split(' ')[0]} {created_at.split(' ')[1]}</p>
                </div>
                <hr/>
                <div class="details">
                    <p><strong>Müşteri:</strong> {name}</p>
                    <p><strong>Telefon:</strong> {phone}</p>
                    <p><strong>TC:</strong> {tc}</p>
                </div>
                <hr/>
                <table class="items-table">
                    <thead>
                        <tr><th>Ürün</th><th>Adet</th><th>Birim F.</th><th>Toplam</th></tr>
                    </thead>
                    <tbody>
                        {items_html}
                    </tbody>
                </table>
                <hr/>
                <div class="total">
                    <p>TOPLAM: {total_price:.2f} ₺</p>
                </div>
                <div class="footer">
                    <p>Bizi tercih ettiğiniz için teşekkür ederiz.</p>
                </div>
            </div>
        </body>
        </html>
        """
        return html

