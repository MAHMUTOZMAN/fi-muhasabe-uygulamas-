    def save_accounting_record(self):
        record_type = "income" if self.accounting_type_combo.currentIndex() == 0 else "expense"
        description = self.accounting_description_input.text().strip()
        amount_text = self.accounting_amount_input.text().strip().replace(',', '.')

        if not description or not amount_text:
            QMessageBox.warning(self, "Hata", "Açıklama ve miktar boş bırakılamaz.")
            return

        try:
            amount = float(amount_text)
            self.db.insert_income_expense(record_type, description, amount)
            QMessageBox.information(self, "Başarılı", "Kayıt başarıyla eklendi.")
            self.accounting_description_input.clear()
            self.accounting_amount_input.clear()
            self.load_accounting_table()
            self.update_dashboard_data()
        except ValueError:
            QMessageBox.warning(self, "Hata", "Lütfen geçerli bir miktar girin.")

    def load_accounting_table(self):
        self.accounting_table.setRowCount(0)
        start_date = self.accounting_start_date.date()
        end_date = self.accounting_end_date.date()

        records = self.db.fetch_all_income_expenses(start_date, end_date)
        self.accounting_table.setRowCount(len(records))

        for row_num, row_data in enumerate(records):
            rec_id, record_type, description, amount, created_at = row_data

            # Tip metnini ve rengini ayarla
            type_text = "Gelir" if record_type == "income" else "Gider"
            color = QColor("#10b981") if record_type == "income" else QColor("#ef4444")

            id_item = QTableWidgetItem(str(rec_id))
            type_item = QTableWidgetItem(type_text)
            description_item = QTableWidgetItem(description)
            amount_item = QTableWidgetItem(f"{amount:,.2f} ₺")
            date_item = QTableWidgetItem(created_at.split(' ')[0])

            type_item.setForeground(color)
            amount_item.setForeground(color)

            self.accounting_table.setItem(row_num, 0, id_item)
            self.accounting_table.setItem(row_num, 1, type_item)
            self.accounting_table.setItem(row_num, 2, description_item)
            self.accounting_table.setItem(row_num, 3, amount_item)
            self.accounting_table.setItem(row_num, 4, date_item)

    def delete_accounting_record(self):
        selected_rows = self.accounting_table.selectionModel().selectedRows()
        if not selected_rows:
            QMessageBox.warning(self, "Hata", "Lütfen silinecek bir kayıt seçin.")
            return

        reply = QMessageBox.question(self, "Onay",
                                     "Seçili kaydı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.",
                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
        if reply == QMessageBox.Yes:
            row_index = selected_rows[0].row()
            rec_id = int(self.accounting_table.item(row_index, 0).text())
            self.db.delete_income_expense(rec_id)
            self.load_accounting_table()
            self.update_dashboard_data()
            QMessageBox.information(self, "Başarılı", "Kayıt başarıyla silindi.")


