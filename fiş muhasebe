    def save_product(self):
        code = self.product_code_edit.text().strip()
        name = self.product_name_edit.text().strip()
        price_text = self.product_price_edit.text().strip().replace(',', '.')
        stock = self.product_stock_edit.value()
        min_stock = self.product_min_stock_edit.value()
        description = self.product_description_edit.toPlainText().strip()

        if not code or not name or not price_text:
            QMessageBox.warning(self, "Hata", "Ürün kodu, adı ve fiyatı boş bırakılamaz.")
            return

        try:
            price = float(price_text)
        except ValueError:
            QMessageBox.warning(self, "Hata", "Lütfen geçerli bir fiyat girin.")
            return

        if self.product_id_label.text() == "Yeni Ürün":
            try:
                self.db.insert_product(code, name, price, stock, min_stock, description)
                QMessageBox.information(self, "Başarılı", "Yeni ürün başarıyla kaydedildi.")
            except sqlite3.IntegrityError:
                QMessageBox.warning(self, "Hata", "Bu ürün kodu zaten mevcut.")
        else:
            prod_id = int(self.product_id_label.text())
            self.db.update_product(prod_id, code, name, price, stock, min_stock, description)
            QMessageBox.information(self, "Başarılı", "Ürün başarıyla güncellendi.")

        self.clear_product_form()
        self.load_products_table()
        self.load_all_product_data()
        self.update_dashboard_data()

    def clear_product_form(self):
        self.product_id_label.setText("Yeni Ürün")
        self.product_code_edit.clear()
        self.product_name_edit.clear()
        self.product_price_edit.clear()
        self.product_stock_edit.setValue(0)
        self.product_min_stock_edit.setValue(5)
        self.product_description_edit.clear()
        self.save_product_button.setText("Kaydet")
        self.product_code_edit.setEnabled(True)

    def load_products_table(self):
        self.products_table.setRowCount(0)
        products = self.db.fetch_all_products()
        self.products_table.setRowCount(len(products))
        for row_num, row_data in enumerate(products):
            prod_id, code, name, price, stock, min_stock, description = row_data
            self.products_table.setItem(row_num, 0, QTableWidgetItem(str(prod_id)))
            self.products_table.setItem(row_num, 1, QTableWidgetItem(code))
            self.products_table.setItem(row_num, 2, QTableWidgetItem(name))
            self.products_table.setItem(row_num, 3, QTableWidgetItem(f"{price:.2f} ₺"))
            self.products_table.setItem(row_num, 4, QTableWidgetItem(str(stock)))
            self.products_table.setItem(row_num, 5, QTableWidgetItem(description))

    def edit_product(self, row):
        prod_id = int(self.products_table.item(row, 0).text())
        product = self.db.fetch_product_by_id(prod_id)
        if product:
            prod_id, code, name, price, stock, min_stock, description = product
            self.product_id_label.setText(str(prod_id))
            self.product_code_edit.setText(code)
            self.product_code_edit.setEnabled(False)  # Ürün kodu değiştirilemez
            self.product_name_edit.setText(name)
            self.product_price_edit.setText(f"{price:.2f}")
            self.product_stock_edit.setValue(stock)
            self.product_min_stock_edit.setValue(min_stock)
            self.product_description_edit.setText(description)
            self.save_product_button.setText("Güncelle")

    def delete_product_record(self):
        selected_rows = self.products_table.selectionModel().selectedRows()
        if not selected_rows:
            QMessageBox.warning(self, "Hata", "Lütfen silinecek bir ürün seçin.")
            return

        reply = QMessageBox.question(self, "Onay",
                                     "Seçili ürünü kalıcı olarak silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.",
                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
        if reply == QMessageBox.Yes:
            row_index = selected_rows[0].row()
            prod_id = int(self.products_table.item(row_index, 0).text())
            self.db.delete_product(prod_id)
            self.load_products_table()
            self.load_all_product_data()
            self.update_dashboard_data()
            QMessageBox.information(self, "Başarılı", "Ürün başarıyla silindi.")
            self.clear_product_form()

