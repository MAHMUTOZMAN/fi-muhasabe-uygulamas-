        total_receipt_revenue = Decimal(report_data['total_revenue'])
        total_other_income = Decimal(report_data['total_other_income'])
        total_expenses = Decimal(report_data['total_expenses'])

        net_profit = (total_receipt_revenue + total_other_income) - total_expenses

        self.total_revenue_label.setText(f"{total_receipt_revenue:,.2f} ₺")
        self.total_other_income_label.setText(f"{total_other_income:,.2f} ₺")
