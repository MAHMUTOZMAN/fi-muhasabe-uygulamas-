    def export_table_to_csv(self):
        current_tab_index = self.tab_widget.currentIndex()
        if current_tab_index == 1:  # Fiş Yönetimi
            table_widget = self.receipts_table
            filename = "fiş_listesi"
        elif current_tab_index == 2:  # Ürün Yönetimi
            table_widget = self.products_table
            filename = "ürün_listesi"
        elif current_tab_index == 3:  # Muhasebe Yönetimi
            table_widget = self.accounting_table
            filename = "muhasebe_kayıtları"
        elif current_tab_index == 4:  # Raporlama
            table_widget = self.report_product_table
            filename = "rapor_urun_kirilimi"
        elif current_tab_index == 5:  # Arşiv
            table_widget = self.archive_table
            filename = "arşiv_listesi"
        else:
            QMessageBox.warning(self, "Uyarı", "Bu sekmedeki veriler CSV'ye aktarılamaz.")
            return

        file_dialog = QFileDialog(self)
        file_path, _ = file_dialog.getSaveFileName(self, "CSV Olarak Kaydet",
                                                   f"{filename}_{datetime.now().strftime('%Y%m%d')}.csv",
                                                   "CSV Dosyaları (*.csv)")

        if file_path:
            with open(file_path, 'w', newline='', encoding='utf-8') as file:
                writer = csv.writer(file)

                # Başlıkları yaz
                headers = [table_widget.horizontalHeaderItem(i).text() for i in range(table_widget.columnCount())]
                writer.writerow(headers)

                # Veriyi yaz
                for row in range(table_widget.rowCount()):
                    row_data = []
                    for col in range(table_widget.columnCount()):
                        item = table_widget.item(row, col)
                        if item:
                            row_data.append(item.text())
                        else:
                            row_data.append('')
                    writer.writerow(row_data)

            QMessageBox.information(self, "Başarılı", f"Veriler başarıyla '{file_path}' dosyasına aktarıldı.")

